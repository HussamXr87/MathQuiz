{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build with GNU Compuler",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/*",
                "-I ${workspaceFolder}/include/",
                "-o",
                "${workspaceFolder}/bin/${workspaceFolderBasename}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "compiler: /usr/bin/g++"
        }
    ],
    "version": "2.0.0"
}